DATABASE_URL=postgresql://<db-user>:<db-password>@postgres:5432/uspsa_analytics
POSTGRES_USER=<set-db-username>
POSTGRES_PASSWORD=<set-strong-password>
POSTGRES_DB=uspsa_analytics

SECRET_KEY=<generate-with-openssl-rand-hex-32>

CACHE_TTL=86400
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=<set-strong-redis-password>

ENVIRONMENT=development
LOG_LEVEL=INFO
